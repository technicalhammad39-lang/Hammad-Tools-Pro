# GEMINI_API_KEY: Required for Gemini AI API calls.
# Set this in your hosting environment or local .env file.
# Use a secure secret manager for production deployments.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this app is hosted.
# Used for self-referential links and API URL resolution.
APP_URL="https://hammadtools.com"
NEXT_PUBLIC_APP_URL="https://hammadtools.com"

# Firebase Web Client (required for login/signup/forgot-password on frontend)
NEXT_PUBLIC_FIREBASE_API_KEY="your-firebase-web-api-key"
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="your-project.firebaseapp.com"
NEXT_PUBLIC_FIREBASE_PROJECT_ID="your-project-id"
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET="your-project.appspot.com"
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID="1234567890"
NEXT_PUBLIC_FIREBASE_APP_ID="1:1234567890:web:abcdef123456"
# Optional:
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID="G-XXXXXXXXXX"
NEXT_PUBLIC_FIRESTORE_DATABASE_ID="(default)"
# Optional custom reset URL (must start with https://hammadtools.com/reset-password)
NEXT_PUBLIC_PASSWORD_RESET_URL="https://hammadtools.com/reset-password"

# Firebase Admin (required for secure API routes, order approval, push sends)
# Explicit credentials only (no default Google application credentials fallback).
FIREBASE_PROJECT_ID="your-project-id"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk-xxx@your-project.iam.gserviceaccount.com"
# Preferred for production/Hostinger: base64-encoded PEM content.
FIREBASE_PRIVATE_KEY_BASE64="BASE64_OF_FULL_PRIVATE_KEY_PEM"
# Fallback (supported): raw PEM with escaped newlines.
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n"
GOOGLE_CLOUD_PROJECT="your-project-id"

# Web Push (Firebase Cloud Messaging)
NEXT_PUBLIC_FIREBASE_VAPID_KEY="YOUR_WEB_PUSH_VAPID_KEY"

# Google Business Reviews (Places API)
GOOGLE_PLACES_API_KEY="YOUR_GOOGLE_PLACES_API_KEY"
GOOGLE_PLACE_ID="YOUR_GOOGLE_BUSINESS_PLACE_ID"

# Optional secret to protect cron endpoint if needed
CRON_SECRET="YOUR_CRON_SECRET"

# Hostinger filesystem uploads
# Public files (tools/services/blog/partners/profiles): direct URL serving path.
HOSTINGER_PUBLIC_UPLOAD_ROOT="public/uploads"
# Protected files (payment proofs/chat attachments): not publicly served.
HOSTINGER_PRIVATE_UPLOAD_ROOT="storage/uploads"
# Public URL base mapped to HOSTINGER_PUBLIC_UPLOAD_ROOT.
HOSTINGER_UPLOAD_PUBLIC_BASE="/uploads"
# Global max file size for public uploads in MB.
HOSTINGER_UPLOAD_MAX_MB="8"
# Payment proof max in MB (protected).
HOSTINGER_PAYMENT_PROOF_MAX_MB="5"
# Chat attachment max in MB (protected).
HOSTINGER_CHAT_ATTACHMENT_MAX_MB="10"
# Toggle verbose upload diagnostics/logging.
HOSTINGER_UPLOAD_DEBUG="true"
# Absolute public app URL for generating full file URLs in API responses.
# NEXT_PUBLIC_APP_URL already defined above.


